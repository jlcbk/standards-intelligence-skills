{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/change-packet.schema.json",
  "title": "ChangePacket",
  "type": "object",
  "required": [
    "change_id",
    "change_type",
    "detected_at",
    "summary",
    "version_relation",
    "changed_provisions",
    "affected_topics",
    "review_tasks",
    "confidence",
    "unresolved_issues"
  ],
  "properties": {
    "change_id": {"type": "string"},
    "change_type": {
      "type": "string",
      "enum": [
        "metadata_refresh",
        "new_version",
        "replacement",
        "provision_change",
        "withdrawal",
        "unknown"
      ]
    },
    "detected_at": {"type": "string"},
    "summary": {"type": "string"},
    "old_source_id": {"type": "string"},
    "new_source_id": {"type": "string"},
    "version_relation": {
      "type": "object",
      "required": ["relation"],
      "properties": {
        "relation": {"type": "string"},
        "old_document_id": {"type": "string"},
        "new_document_id": {"type": "string"},
        "old_status": {"type": "string"},
        "new_status": {"type": "string"},
        "old_effective_date": {"type": "string"},
        "new_effective_date": {"type": "string"}
      },
      "additionalProperties": true
    },
    "changed_provisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["change_kind", "summary"],
        "properties": {
          "change_kind": {"type": "string"},
          "old_provision_id": {"type": "string"},
          "new_provision_id": {"type": "string"},
          "locator": {"type": "string"},
          "summary": {"type": "string"},
          "impact_level": {
            "type": "string",
            "enum": ["high", "medium", "low", "unknown"]
          }
        },
        "additionalProperties": true
      }
    },
    "affected_topics": {"type": "array", "items": {"type": "string"}},
    "affected_entities": {"type": "array", "items": {"type": "string"}},
    "review_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "title", "reason", "required_human_decision"],
        "properties": {
          "task_id": {"type": "string"},
          "title": {"type": "string"},
          "reason": {"type": "string"},
          "required_human_decision": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "unresolved_issues": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
